MONGODB_URI="mongodb://localhost:27017/uptimewatch"

# Auth: Clerk JWTs are verified against the issuer's JWKS.
# REQUIRED. This is the allowlist of trusted issuers — the API rejects all
# requests when it is unset. Set it to your Clerk instance issuer URL
# (find it in your Clerk dashboard, e.g. https://your-app.clerk.accounts.dev).
# Comma-separate to allow multiple instances.
CLERK_ISSUER="https://your-app.clerk.accounts.dev"

RESEND_API_KEY=yourresendapikey

# Email "from" address for alerts. Defaults to Resend's test sender.
# Use a domain you've verified in Resend for production.
# EMAIL_FROM="UptimeWatch <noreply@yourdomain.com>"

# Production frontend URL(s) allowed by CORS (comma-separated). localhost is always allowed.
# FRONTEND_URL="https://yourapp.com"
