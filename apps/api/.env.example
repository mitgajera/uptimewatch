MONGODB_URI="mongodb://localhost:27017/uptimewatch"

# Auth: Clerk JWTs are verified via the issuer's JWKS automatically.
# Optionally lock the API to a single Clerk instance by setting its issuer
# (find it in your Clerk dashboard, e.g. https://your-app.clerk.accounts.dev):
# CLERK_ISSUER="https://your-app.clerk.accounts.dev"

RESEND_API_KEY=yourresendapikey
EMAIL_NOTIFICATIONS_ENABLED=false

# Email "from" address for alerts. In production this must be an address
# on a domain verified in Resend.
# If you keep the default onboarding sender, Resend only allows sending to
# your own account email in testing mode.
# EMAIL_FROM="UptimeWatch <noreply@yourdomain.com>"

# Production frontend URL(s) allowed by CORS (comma-separated). localhost is always allowed.
# FRONTEND_URL="https://yourapp.com"
